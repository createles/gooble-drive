<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css"> 
  <title><%= title %></title>
</head>
<body>

  <%- include('partials/notif-message.ejs') %>

  <div class="login-cont">
    <h1>Welcome Back</h1>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">Please log in to access your Drive.</p>

    <form action="/login" method="POST">
      <label for="username">
        Username
        <input type="text" name="username" required>
      </label>

      <label for="password">
        Password
        <input type="password" name="password" required>
      </label>

      <button type="submit" class="btn-upload" style="margin-top: 1rem;">Log in</button>
    </form>

    <div style="margin-top: 1.5rem;">
      <a href="/signup" style="color: var(--primary-color); font-weight: 500;">Need an account? Sign up</a>
    </div>
  </div>
</body>
</html>