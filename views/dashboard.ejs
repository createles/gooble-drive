<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gooble Drive - <%= title %></title>
  <link rel="stylesheet" href="/style.css"> 
</head>
<body class="dashboard-layout">

  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <%- include('partials/add-btn.ejs') %>
  <%- include('partials/upload-modal.ejs') %>
  <%- include('partials/options-menu.ejs') %>
  <%- include('partials/share-modal.ejs') %>
  <%- include('partials/move-modal.ejs') %>

  <!-- Main Content Area -->
  <main class="app-main">
    
    <!-- Clickable Navigation Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/dashboard" class="breadcrumb-link">My Drive</a>
      
      <% if (currentFolder) { %>
        <span class="breadcrumb-separator">></span>
        <a href="/dashboard/<%= currentFolder.id %>" class="breadcrumb-link">
          <%= currentFolder.name %>
        </a>
      <% } %>
      
    </div>

    <!-- Conditional Rendering based on database contents -->
    <% if ((locals.folders && folders.length > 0) || (locals.files && files.length > 0)) { %>
      
      <div 
      class="item-grid"
      data-current-folder-id="<%= currentFolder ? currentFolder.id : 'root' %>">
        <!-- Loop over folders -->
        <% folders.forEach(folder => { %>
        <a href="/dashboard/<%= folder.id %>" 
          class="grid-item"
          data-type="folder"
          data-id="<%= folder.id %>"
          data-name="<%= folder.name %>"
          data-size="==="
          data-date="<%= folder.createdOn.toDateString() %>">
          <button class="options-btn">&#8942;</button>
          <div class="folder-icon" style="font-size: 2rem;">📁</div>
          <div class="item-name"><%= folder.name %></div>
        </a>
      <% }) %>

      <!-- Loop over files -->
      <% files.forEach(file => { %>
        <div class="grid-item"
          data-type="file"
          data-id="<%= file.id %>" 
          data-name="<%= file.name %>" 
          data-size="<%= (file.size / 1024).toFixed(1) %> KB" 
          data-date="<%= file.uploadTime.toDateString() %>">
          <button class="options-btn">&#8942;</button>
          <div class="file-icon" style="font-size: 2rem;">📄</div>
          <div class="item-name"><%= file.name %></div>
          <div class="item-size" style="font-size: 0.8rem; color: var(--text-muted);">
            <%= (file.size / 1024).toFixed(1) %> KB
          </div>
        </div>
      <% }) %>
      </div>

    <% } else { %>

      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-state-content">
          <p>This directory is currently empty.</p>
          <button class="btn-upload empty-upload-btn">Upload a File or Folder</button>
        </div>
      </div>

    <% } %>
  </main>
  
  <!-- Details Modal Pane -->
  <%- include('partials/details-modal.ejs') %>
  
  <script>

    // === DOM ELEMENTS ===
    const dom = {
    layout: document.querySelector('.dashboard-layout'),
    grid: document.querySelector('.item-grid'),
    modals: {
      upload: document.getElementById('uploadModal'),
      details: document.getElementById('detailsModal'),
      share: document.getElementById('shareModal'),
      move: document.getElementById('moveModal')
    },
    upload: {
      fileInput: document.getElementById('file'),
    },
    details: {
      name: document.getElementById('detailName'),
      type: document.getElementById('detailType'),
      size: document.getElementById('detailSize'),
      date: document.getElementById('detailDate')
    },
    share: {
      setup: document.getElementById('shareSetup'),
      result: document.getElementById('shareResult'),
      fileId: document.getElementById('shareFileId'),
      duration: document.getElementById('shareDuration'),
      linkInput: document.getElementById('generatedLink')
    },
    options: {
      menu: document.getElementById('optionsMenu'),
      details: document.getElementById('optionsDetailsBtn'),
      download: document.getElementById('optionsDlBtn'),
      share: document.getElementById('optionsShareBtn'),
      delete: document.getElementById('optionsDeleteBtn'),
      rename: document.getElementById('optionsRenameBtn'),
      copy: document.getElementById('optionsCopyBtn'),
      move: document.getElementById('optionsMoveBtn'),
    },
  };

  // === VISIBILITY TOGGLE HELPER ===
  const toggleUI = (el, force) => el.classList.toggle('active', force);

  // === GRID ITEM BEHAVIOR ===

  const syncDetailsPane = (item) => {
    // Populate Details Pane
    dom.details.name.textContent = item.dataset.name;
    dom.details.type.textContent = item.dataset.type;
    dom.details.size.textContent = item.dataset.size;
    dom.details.date.textContent = item.dataset.date;
  }

  dom.grid?.addEventListener('click', (e) => {
    const item = e.target.closest('.grid-item');
    if (!item) return;

    // FIX: "Stop" navigation on single click for folders
    if (item.tagName === 'A') e.preventDefault();

    syncDetailsPane(item);
  });

  // Double click allows navigating into a folder
  dom.grid?.addEventListener('dblclick', (e) => {
    const item = e.target.closest('.grid-item');
    const destination = item?.getAttribute('href');
    // "Go" navigation on double click
    if (destination) window.location.href = destination;
  });

  // === OPTIONS MENU LOGIC ===
  const showOptionsMenu = (e) => {
    const item = e.target.closest('.grid-item');
    const itemId = item.dataset.id;
    const itemType = item.dataset.type;
    const itemName = item.dataset.name;
    
    syncDetailsPane(item);

    e.preventDefault();
    e.stopPropagation();

    // Stamp ID onto options menu
    dom.options.menu.dataset.activeId = itemId;
    dom.options.menu.dataset.activeType = itemType;
    dom.options.menu.dataset.activeName = itemName;

    // Update Menu Buttons
    dom.options.download.href = `/download/${itemId}`;

    // Position and Show
    dom.options.menu.style.top = `${e.pageY}px`;
    dom.options.menu.style.left = `${e.pageX}px`;
    toggleUI(dom.options.menu, true);
  };

  document.querySelectorAll('.options-btn').forEach(btn => 
    btn.addEventListener('click', showOptionsMenu)
  );

  // === VIEW DETAILS ===
  dom.options.details.addEventListener('click', () => {
    dom.layout.classList.add('show-details');
    toggleUI(dom.options.menu, false);
  })

  // === SHARE FEATURE (Fetch API) ===
  const openShareModal = (fileId) => {
    dom.share.fileId.value = fileId;
    // toggleUI(dom.share.setup, true);
    // toggleUI(dom.share.result, false);
    toggleUI(dom.modals.share, true);
  };

  dom.options.share?.addEventListener('click', () => {
    dom.options.menu.classList.remove('active');
    const fileId = dom.options.menu.dataset.activeId;
    openShareModal(fileId);
  });

  async function handleShareClick() {
    // payload = file to share's id and selected duration
    const payload = {
      fileId: dom.share.fileId.value,
      duration: dom.share.duration.value
    };

    try {
      const response = await fetch('/files/share', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await response.json();

      if (data.shareLink) {
        dom.share.linkInput.value = data.shareLink;
        // toggleUI(dom.share.setup, false);
        // toggleUI(dom.share.result, true);
      }
    } catch (err) {
      console.error("Share failed", err);
      alert("Could not generate link.");
    }
  }

  async function copyGeneratedLink() {
    await navigator.clipboard.writeText(dom.share.linkInput.value);
    alert("Link copied to clipboard!");
  }


  // === RENAME FILE/FOLDER LOGIC ===
  dom.options.rename.addEventListener('click', async () => {
    const id = dom.options.menu.dataset.activeId;
    const type = dom.options.menu.dataset.activeType;
    
    // Quick way to get the existing name from the dashboard UI
    const itemElement = document.querySelector(`.grid-item[data-id="${id}"][data-type="${type}"]`);
    
    if (!itemElement) return console.error("Could not find element to rename");
    
    const oldName = itemElement.querySelector('.item-name').innerText;
    const newName = prompt(`Enter new name for this ${type}:`, oldName);

    if (newName && newName !== oldName) {
      const response = await fetch(`/${type}s/${id}/rename`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ newName })
      });

      if (response.ok) {
        window.location.reload();
      } else {
        alert(`Could not rename ${type}. Please try again.`);
      }
    }
  });


  // === DELETE FILE/FOLDER LOGIC ===
  dom.options.delete.addEventListener('click', async () => {
    const itemId = dom.options.menu.dataset.activeId;
    const itemType = dom.options.menu.dataset.activeType;
    
    const confirmDelete = confirm(`Are you sure you want to delete this ${itemType}?`);
    if (!confirmDelete) return;

    try {
      // Determine route based on type
      const route = `/${itemType}s/${itemId}/delete`;
      
      const response = await fetch(route, { method: 'DELETE' });
      // Holds json object containing success status after calling deleteFile
      const result = await response.json();


      if (result.success) {
        window.location.reload(); // Refresh to update grid
      } else {
        alert("Error deleting item.");
      }
    } catch (err) {
      console.error("Delete failed:", err);
    }
  });


  // === MOVE FILE/FOLDER LOGIC ===
  const moveForm = document.getElementById('moveForm');
  const folderSelect = document.getElementById('folderSelect');

  dom.options.move.addEventListener('click', async () => {
    dom.options.menu.classList.remove('active');
    const id = dom.options.menu.dataset.activeId;
    const type = dom.options.menu.dataset.activeType;
    const name = dom.options.menu.dataset.activeName;
    const currentViewFolder = document.querySelector('.item-grid').dataset.currentFolderId;
    const moveFolderName = document.getElementById('moveFolderName');
    const moveFileName = document.getElementById('moveFileName');

    // Pass active info to the server
    const response = await fetch(`/folders?movingId=${id}&type=${type}`);
    const folders = await response.json();

    // 'Reset'/'Clear' options except root folder
    folderSelect.innerHTML = `
    <option value="" disabled selected>— Select Destination —</option>
    <option value="root" id="moveRoot">Dashboard (Root)</option>
    `;
    const rootOption = document.getElementById('moveRoot');

    // PRE-CHECK: If we are already at the root, disable the Root option
    if (currentViewFolder === 'root') {
      rootOption.disabled = true;
      rootOption.textContent += ' (current location)';
      rootOption.style.color = '#999';
    }
    
    // Display possible folder destinations
    folders.forEach(folder => {
      const option = document.createElement('option');
      option.value = folder.id;
      option.textContent = folder.name;

      if (folder.isInvalid) {
        option.disabled = true;
        if (folder.id === parseInt(id)) {
          option.textContent += ' (cannot move into self)';
        } else {
          option.textContent += ' (cannot move into sub-nested folder)';
        }

        option.style.color = '#999'; // visual grey out

      // If current location folder, already in folder
      } else if (folder.id == currentViewFolder) {
        option.disabled = true;
        option.textContent += ' (current location)';
        option.style.color = '#999';
      }

      folderSelect.appendChild(option);
    });

    document.getElementById('moveItemType').textContent = type;
    if (type === 'folder') {
      moveFolderName.style.display = 'block';
      moveFolderName.textContent += `${name}`;
    } else {
      moveFileName.style.display = 'block';
      moveFileName.textContent += `${name}`;
    }
    dom.modals.move.classList.add('active');
  });


  // Submitting destination folder for Move
  moveForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = dom.options.menu.dataset.activeId;
    const type = dom.options.menu.dataset.activeType;
    const destinationId = folderSelect.value;

    // Guard against immediate submission; if value is empty, no destination folder selected
    if (!destinationId) {
      alert("Please select a destination folder.");
      return;
    }

    const response = await fetch (`/${type}s/${id}/move`, {
      method: 'PATCH',
      headers: { 'Content-type': 'application/json' },
      body: JSON.stringify({ destinationId })
    });

    if (response.ok) {
      window.location.reload();
    } else {
      const err = await response.json();
      alert(err.error || 'Move failed.');
    }
  });


  // === COPY FILES LOGIC ===
  dom.options.copy.addEventListener('click', async () => {
    const id = dom.options.menu.dataset.activeId;
    if (!id) return;

    try {
      const response = await fetch(`/files/${id}/copy`, {
        method: 'POST',
        header: { 'Content-Type' : 'application/json' }
      });

      const result = await response.json();
      
      if (result.success) {
        window.location.reload();
      } else {
        alert(result.error || "Failed to copy file.");
      }
    } catch (err) {
      console.error("Error copying file:", err);
    } finally {
      toggleUI(dom.options.menu, false);
    }
  })

  // === UPLOAD MODAL ===
  const openUploadModal = () => toggleUI(dom.modals.upload, true);
  const tabUpload = document.getElementById('tabUpload');
  const tabFolder = document.getElementById('tabFolder');
  const formUpload = document.getElementById('formUploadCont');
  const formFolder = document.getElementById('formFolderCont');
  document.getElementById('openUploadModal')?.addEventListener('click', openUploadModal);
  document.querySelector('.empty-upload-btn')?.addEventListener('click', openUploadModal);

  // Add alert for file sizes larger than 10MB
  dom.upload.fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file && file.size > 10 * 1024 * 1024 ) {
      alert('This file is too large to upload (Max 10MB).');
      e.target.value = ""; // Clear the upload input
    }
  });

  // Tab Switching Helper
  const switchTab = (activeTab, inactiveTab, showForm, hideForm) => {
    activeTab.classList.add('active');
    activeTab.classList.remove('inactive');
    inactiveTab.classList.add('inactive');
    inactiveTab.classList.remove('active');
    showForm.style.display = 'block';
    hideForm.style.display = 'none';
  };

  tabUpload.addEventListener('click', () => {
    switchTab(tabUpload, tabFolder, formUpload, formFolder);
  });

  tabFolder.addEventListener('click', () => {
    switchTab(tabFolder, tabUpload, formFolder, formUpload);
  });

  // === GLOBAL CLOSING LOGIC ===
  window.addEventListener('click', (e) => {
    // Close modals if dark overlay is clicked
    if (e.target === dom.modals.upload) toggleUI(dom.modals.upload, false);
    if (e.target === dom.modals.share) toggleUI(dom.modals.share, false);
    if (e.target === dom.modals.move) toggleUI(dom.modals.move, false);

    // Close options menu if clicking outside
    if (dom.options.menu.classList.contains('active') && !dom.options.menu.contains(e.target)) {
      dom.options.menu.classList.remove('active');
    }

    // Close details pane if clicking empty grid space
    if (dom.layout.classList.contains('show-details') && (e.target === dom.grid || e.target === document.querySelector('.app-main'))) {
      dom.layout.classList.remove('show-details');
    }
  });

  // Explicit close buttons
  const hideAllModals = () => {
    // Object.values selects all modals, .forEach modal attaches toggle
    Object.values(dom.modals).forEach(modal => toggleUI(modal, false));
    dom.options.menu.classList.remove('active');
    dom.layout.classList.remove('show-details');
  };

  document.querySelectorAll('.close-modal, #closeDetails, #closeUploadModal, #closeMoveModal, #closeShareModal').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      hideAllModals();
    });
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hideAllModals();
  });

  </script>
</body>
</html>