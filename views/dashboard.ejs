<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css"> 
</head>
<body class="dashboard-layout">

  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <%- include('partials/add-btn.ejs') %>
  <%- include('partials/upload-modal.ejs') %>

  <!-- Main Content Area -->
  <main class="app-main">
    
    <!-- Clickable Navigation Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/dashboard" class="breadcrumb-link">My Drive</a>
      <!-- We will dynamically add more links here when users click into nested folders -->
      <!-- Example: <span class="breadcrumb-separator">></span> <a href="#" class="breadcrumb-link">Vacation Photos</a> -->
    </div>

    <!-- Conditional Rendering based on database contents -->
    <% if ((locals.folders && folders.length > 0) || (locals.files && files.length > 0)) { %>
      
      <div class="item-grid">
        <!-- We will use an EJS loop here later to render each folder/file -->
        <!-- Example mock item: -->
        <div class="grid-item">
          📄 example-file.pdf
        </div>
      </div>

    <% } else { %>

      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-state-content">
          <p>This directory is currently empty.</p>
          <button class="btn-upload trigger-modal">Upload a File or Folder</button>
        </div>
      </div>

    <% } %>

  </main>
  <script>
    const modal = document.getElementById('uploadModal');
    const openBtn = document.getElementById('openUploadModal');
    const closeBtn = document.getElementById('closeUploadModal');
    const triggerBtns = document.querySelectorAll('.trigger-modal');

    const toggleModal = () => modal.classList.toggle('active');

    // Open from Floating Button
    openBtn.addEventListener('click', toggleModal);

    // Open from Empty State Button
    triggerBtns.forEach(btn => btn.addEventListener('click', toggleModal));

    // Close from X button
    closeBtn.addEventListener('click', toggleModal);

    // Close if clicking outside the modal content
    window.addEventListener('click', (e) => {
      if (e.target === modal) toggleModal();
    });
  </script>
</body>
</html>