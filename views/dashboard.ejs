<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gooble Drive - <%= title %></title>
  <link rel="stylesheet" href="/style.css"> 
</head>
<body class="dashboard-layout">

  <%- include('partials/header') %>
  <%- include('partials/sidebar') %>
  <%- include('partials/add-btn.ejs') %>
  <%- include('partials/upload-modal.ejs') %>
  <%- include('partials/options-menu.ejs') %>
  <%- include('partials/share-modal.ejs') %>

  <!-- Main Content Area -->
  <main class="app-main">
    
    <!-- Clickable Navigation Breadcrumbs -->
    <div class="breadcrumbs">
      <a href="/dashboard" class="breadcrumb-link">My Drive</a>
      
      <% if (currentFolder) { %>
        <span class="breadcrumb-separator">></span>
        <a href="/dashboard/<%= currentFolder.id %>" class="breadcrumb-link">
          <%= currentFolder.name %>
        </a>
      <% } %>
      
    </div>

    <!-- Conditional Rendering based on database contents -->
    <% if ((locals.folders && folders.length > 0) || (locals.files && files.length > 0)) { %>
      
      <div class="item-grid">
        <!-- Loop over folders -->
        <% folders.forEach(folder => { %>
        <a href="/dashboard/<%= folder.id %>" 
          class="grid-item"
          data-type="Folder"
          data-name="<%= folder.name %>"
          data-size=""
          data-date="<%= folder.createdOn.toDateString() %>">
          <button class="options-btn">&#8942;</button>
          <div class="folder-icon" style="font-size: 2rem;">📁</div>
          <div class="item-name"><%= folder.name %></div>
        </a>
      <% }) %>

      <!-- Loop over files -->
      <% files.forEach(file => { %>
        <div class="grid-item"
          data-type="File"
          data-id="<%= file.id %>" 
          data-name="<%= file.name %>" 
          data-size="<%= (file.size / 1024).toFixed(1) %> KB" 
          data-date="<%= file.uploadTime.toDateString() %>">
          <button class="options-btn">&#8942;</button>
          <div class="file-icon" style="font-size: 2rem;">📄</div>
          <div class="item-name"><%= file.name %></div>
          <div class="item-size" style="font-size: 0.8rem; color: var(--text-muted);">
            <%= (file.size / 1024).toFixed(1) %> KB
          </div>
        </div>
      <% }) %>
      </div>

    <% } else { %>

      <!-- Empty State -->
      <div class="empty-state">
        <div class="empty-state-content">
          <p>This directory is currently empty.</p>
          <button class="btn-upload trigger-modal">Upload a File or Folder</button>
        </div>
      </div>

    <% } %>
  </main>
  
  <!-- Details Modal Pane -->
  <%- include('partials/details-modal.ejs') %>
  
  <script>
    const uploadModal = document.getElementById('uploadModal');
    const openBtn = document.getElementById('openUploadModal');
    const closeBtn = document.getElementById('closeUploadModal');
    const triggerBtns = document.querySelectorAll('.trigger-modal');

    const toggleModal = () => uploadModal.classList.toggle('active');

    // Open from Floating Button
    openBtn.addEventListener('click', toggleModal);
    // Open from Empty State Button
    triggerBtns.forEach(btn => btn.addEventListener('click', toggleModal));
    // Close from X button
    closeBtn.addEventListener('click', toggleModal);

  // --- GRID-ITEM CLICK LOGIC ---
    const gridItems = document.querySelectorAll('.grid-item');
    const dashboardLayout = document.querySelector('.dashboard-layout'); // Target the layout container
    const detailsModal = document.querySelector('#detailsModal');
    const shareModal = document.querySelector('#shareModal');

    let activeItemData = {};

    const showDetailsModal = (event) => {
      const item = event.currentTarget;
      
      // Update Details modal with item data
      activeItemData = {
        name: item.dataset.name,
        type: item.dataset.type,
        size: item.dataset.size,
        date: item.dataset.date
      };

      document.getElementById('detailName').textContent = activeItemData.name;
      document.getElementById('detailType').textContent = activeItemData.type;
      document.getElementById('detailSize').textContent = activeItemData.size;
      document.getElementById('detailDate').textContent = activeItemData.date;

      // ONLY trigger the entrance animation if the panel is currently hidden
      if (!dashboardLayout.classList.contains('show-details')) {
        dashboardLayout.classList.add('show-details');
      }
    };

    gridItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        // Pass e to provide click target element
        showDetailsModal(e); 
      });

      item.addEventListener('dblclick', (e) => {
        const destination = e.currentTarget.getAttribute('href');
        if (destination) {
          window.location.href = destination;
        }
      });
    });

    // Close button in Details Pane 
    const closeDetails = document.querySelector('#closeDetails');
    closeDetails.addEventListener('click', () => dashboardLayout.classList.remove('show-details'));

  // --- OPTIONS MENU LOGIC ---
    const optionsMenu = document.getElementById('optionsMenu');
    const optionsBtns = document.querySelectorAll('.options-btn');
    const optionsDownloadBtn = document.querySelector('#optionsDlBtn');
    const optionsShareBtn = document.querySelector('#optionsShareBtn');

    const showOptionsMenu = (event) => {
      optionsMenu.classList.remove('active')
      event.preventDefault(); // Prevent <a> tag navigation
      event.stopPropagation(); // Stop click from bubbling
      optionsDownloadBtn.href = `/download/${event.target.closest(".grid-item").dataset.id}`
      optionsShareBtn.dataset.id = event.target.closest('.grid-item').dataset.id;
      optionsMenu.style.top = `${event.pageY}px`;
      optionsMenu.style.left = `${event.pageX}px`;
      setTimeout(() => {
        optionsMenu.classList.add('active');
      }, 50)
    };

    const hideOptionsMenu = () => {
      optionsMenu.classList.remove('active');
    };

    optionsBtns.forEach(btn => btn.addEventListener('click', showOptionsMenu));

    // Select Upload Tabs and Forms
    const tabUpload = document.getElementById('tabUpload');
    const tabFolder = document.getElementById('tabFolder');
    const formUpload = document.getElementById('formUploadCont');
    const formFolder = document.getElementById('formFolderCont');

    // Tab switching helper fx
    const switchTab = (activeTab, inactiveTab, showForm, hideForm) => {
      activeTab.classList.add('active');
      activeTab.classList.remove('inactive');
      inactiveTab.classList.add('inactive');
      inactiveTab.classList.remove('active');
      showForm.style.display = 'block';
      hideForm.style.display = 'none';
    };

    tabUpload.addEventListener('click', () => {
      switchTab(tabUpload, tabFolder, formUpload, formFolder);
    });

    tabFolder.addEventListener('click', () => {
      switchTab(tabFolder, tabUpload, formFolder, formUpload);
    });
  
  // --- SHARE MODAL LOGIC ---
  // Opens modal and populates the hidden file ID
  function openShareModal(fileId) {
    document.getElementById('shareFileId').value = fileId;
    document.getElementById('shareModal').classList.add('active');
  }

  // Gather data and sends the fetch request
  async function handleShareClick() {
    const fileId = document.getElementById('shareFileId').value;
    const duration = document.getElementById('shareDuration').value;

    try {
      const response = await fetch('/files/share', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fileId, duration })
      });

      const data = await response.json();

      if (data.shareLink) {
        document.getElementById('generatedLink').value = data.shareLink;
        document.getElementById('shareSetup').classList.remove('active');
        document.getElementById('shareResult').classList.add('active');
      }
    } catch (err) {
      console.error("Failed to generate link", err);
      alert("Could not generate shareable link. Please try again.");
    }
  }

  function closeShareModal() {
    document.getElementById('shareModal').classList.remove('active');
  }

  // Copy link button handler
  async function copyGeneratedLink() { 
    const linkInput = document.getElementById('generatedLink');
    await navigator.clipboard.writeText(linkInput.value);
    alert("Link copied to clipboard!");
  }
  
  // Share button click behavior
  const shareBtn = document.getElementById('optionsShareBtn');
  shareBtn.addEventListener('click', (e) => {
    const fileId = e.target.dataset.id;
    hideOptionsMenu();
    openShareModal(fileId);
  });

  // Close menus when clicking elsewhere or pressing Escape
  window.addEventListener('click', (e) => {
    // Close modal if clicking on the overlay
    if (e.target === uploadModal) toggleModal();
    // Close options menu if clicking outside
    if (optionsMenu.classList.contains('active') && !optionsMenu.contains(e.target) && !e.target.closest('.options-btn')) {
      hideOptionsMenu();
    }
    // Close details pane if clicking elsewhere
    if (dashboardLayout.classList.contains('show-details') && !detailsModal.contains(e.target)) {
      dashboardLayout.classList.remove('show-details');
    }

    // HIDE MODAL WHEN CLICKING OUT
    // if (share)
  });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') hideOptionsMenu();
  });

  </script>
</body>
</html>