<div class="modal-overlay" id="uploadModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Upload to Drive</h3>
      <button class="close-modal" id="closeUploadModal">&times;</button>
    </div>

    <form action="/upload" method="POST" enctype="multipart/form-data" class="upload-form">
      <div class="form-group">
        <label for="file">Choose File</label>
        <input type="file" name="file" id="file" required>
      </div>

      <!-- Logic for folders can be added later as a separate form or field -->
      <div class="form-group">
        <label for="folderName">Target Folder (Optional)</label>
        <select name="folderName" id="select-folder" disabled>
          <option value="root">Root</option>
        </select>
      </div>

      <button type="submit" class="btn-upload">Upload</button>
    </form>
  </div>
</div>