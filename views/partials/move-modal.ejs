<div id="moveModal" class="modal-overlay">
  <div class="modal-content">
    <h3>Move <span id="moveItemType">item</span></h3>
    <p>Select destination folder:</p>
    
    <form id="moveForm">
      <select name="destinationId" id="folderSelect">
        <option value="root">Dashboard (Root)</option>
        </select>
      
      <div class="modal-buttons">
        <button type="button" id="closeMoveModal" class="btn-secondary">Cancel</button>
        <button type="submit" class="btn-primary">Move</button>
      </div>
    </form>
  </div>
</div>